# Backend env for the Lightsail box. Copy to .env.deploy and fill in.
REINS_AUTH=on
REINS_SESSION_SECRET=__run: openssl rand -hex 32__
REINS_COOKIE_SECURE=on
# Dashboard origin (the Vercel frontend), so admin-CLI reset/join links are clickable.
# The /reset and /join PAGES are served by the frontend, NOT this API host.
REINS_PUBLIC_URL=https://reinshq.vercel.app

# Inference backend: "0g-router" (recommended), "openai", or "0g" (broker SDK)
REINS_LLM_PROVIDER=0g-router

# Model id from the pc.0g.ai catalogue (text LLM). Used for router + openai.
REINS_LLM_MODEL=Qwen2.5-Omni

# 0G Private Computer Router — OpenAI-compatible front door to 0G Compute.
# Get the API key at pc.testnet.0g.ai (connect wallet, deposit 0G, create key).
OG_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
OG_ROUTER_API_KEY=
# Route to privacy-enabled TEE providers (sealed enclaves). off by default.
OG_PRIVATE=off

# LLM (OpenAI-compatible) — used only when REINS_LLM_PROVIDER=openai
REINS_LLM_BASE_URL=https://api.openadapter.in/v1
REINS_LLM_API_KEY=

# 0G Storage — decentralized, verifiable context snapshots (https://docs.0g.ai)
# Needs a TESTNET key with a little 0G for gas. Or place it in server/.0g-key.
OG_STORAGE=on
OG_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Advanced (REINS_LLM_PROVIDER=0g broker SDK only):
# OG_COMPUTE_PROVIDER=        # pin a provider address, else auto-pick
# OG_LEDGER_TOPUP=1           # top up broker ledger to N 0G when low

# Only needed if the browser talks to the backend directly (NEXT_PUBLIC_REINS_URL).
# Left blank, the Vercel rewrite keeps everything same-origin and CORS isn't used.
REINS_CORS_ORIGIN=
