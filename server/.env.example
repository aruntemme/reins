# ── Reins server ────────────────────────────────────────────────
PORT=4319
REINS_DB=./reins.db

# ── Auth / multi-tenancy ────────────────────────────────────────
# off = single open instance (local dev). on = workspaces + tokens (deploy).
REINS_AUTH=off
# Required when REINS_AUTH=on — signs dashboard sessions. `openssl rand -hex 32`.
REINS_SESSION_SECRET=
# Cookie Secure flag: auto (secure in production only) | on | off
REINS_COOKIE_SECURE=auto
# Comma-separated allowed dashboard origins for credentialed CORS (e.g. your Vercel URL).
REINS_CORS_ORIGIN=
# Legacy single shared ingest key (only honored when REINS_AUTH=off).
REINS_INGEST_KEY=

# Master key for encrypting stored model-provider API keys at rest (AES-256-GCM).
# Set a long random value (`openssl rand -hex 32`); blank = auto-generated into ./.reins-secret.
REINS_SECRET_KEY=

# ── Model provider (OpenAI-compatible) ──────────────────────────
# Providers are normally added at runtime from the dashboard (Settings → model
# providers) and stored encrypted in the DB. The vars below are an OPTIONAL
# fallback, used only until a provider is added there.
# Works with OpenAI, OpenRouter, Together, Groq, vLLM, Ollama, LM Studio, etc.
# Examples:
#   OpenAI     : https://api.openai.com/v1
#   OpenRouter : https://openrouter.ai/api/v1
#   Ollama     : http://localhost:11434/v1   (api key can be any non-empty string)
#   LM Studio  : http://localhost:1234/v1
REINS_LLM_BASE_URL=https://api.openai.com/v1
REINS_LLM_API_KEY=
# Main reasoning model (extraction + reconciliation + rollup)
REINS_LLM_MODEL=gpt-4o
# Cheaper/faster model for the triage gate (optional; falls back to REINS_LLM_MODEL)
REINS_LLM_MODEL_FAST=gpt-4o-mini
# Per-request safety cap
REINS_LLM_MAX_TOKENS=2000
