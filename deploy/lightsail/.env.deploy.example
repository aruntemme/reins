# Backend env for the Lightsail box. Copy to .env.deploy and fill in.
REINS_AUTH=on
REINS_SESSION_SECRET=__run: openssl rand -hex 32__
REINS_COOKIE_SECURE=on
# Dashboard origin (the Vercel frontend), so admin-CLI reset/join links are clickable.
# The /reset and /join PAGES are served by the frontend, NOT this API host.
REINS_PUBLIC_URL=https://reinshq.vercel.app

# Master key for encrypting stored provider API keys at rest (AES-256-GCM).
# Set a long random value; otherwise the server auto-generates ./.reins-secret.
REINS_SECRET_KEY=__run: openssl rand -hex 32__

# Model providers are configured in the dashboard (Settings → model providers),
# encrypted in the DB. The vars below are an OPTIONAL fallback used only until a
# provider is added there — any OpenAI-compatible gateway works.
REINS_LLM_MODEL=
REINS_LLM_BASE_URL=https://api.openai.com/v1
REINS_LLM_API_KEY=

# Only needed if the browser talks to the backend directly (NEXT_PUBLIC_REINS_URL).
# Left blank, the Vercel rewrite keeps everything same-origin and CORS isn't used.
REINS_CORS_ORIGIN=
