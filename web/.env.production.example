# Vercel project env (Production + Preview).
# The Next rewrite in next.config.mjs proxies /api/* to this backend, so the
# browser stays same-origin and sessions remain first-party.
REINS_URL=https://your-reins-backend.example.com

# Optional: connect SSE directly to the backend if your platform buffers the
# rewrite stream. Requires the backend's REINS_CORS_ORIGIN to include this app's origin.
# NEXT_PUBLIC_REINS_URL=https://your-reins-backend.example.com
